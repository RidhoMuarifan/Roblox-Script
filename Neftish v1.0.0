-- TAB MENU 1
local Toggle = Tab:CreateToggle({
   Name = "Fake Height (Melayang)",
   CurrentValue = _G.FakeHeightEnabled,
   Flag = "FakeHeightToggle",
   Callback = function(Value)
      _G.FakeHeightEnabled = Value
      if not Value then
         pcall(function()
            local char = lp.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then 
               hum.HipHeight = 2
               task.wait(0.05)
               hum:ChangeState(Enum.HumanoidStateType.Freefall)
            end
         end)
      end
   end,
})

local Input = Tab:CreateInput({
   Name = "Ketik Ketinggian (Contoh: 200)",
   PlaceholderText = "Ketik angka di sini...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      local numericValue = tonumber(Text)
      if numericValue then
         _G.HeightOffset = numericValue
         if _G.FakeHeightEnabled then
            pcall(function()
               anyChar = lp.Character
               local hum = anyChar and anyChar:FindFirstChildOfClass("Humanoid")
               if hum then hum.HipHeight = numericValue end
            end)
         end
      end
   end,
})

local SpeedInput = Tab:CreateInput({
   Name = "Ketik Kecepatan Jalan (Default: 16)",
   PlaceholderText = "Ketik speed di sini...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      local numericValue = tonumber(Text)
      if numericValue then
         _G.CustomSpeed = numericValue
      else
         _G.CustomSpeed = 16
      end
   end,
})

local JumpInput = Tab:CreateInput({
   Name = "Ketik Kecepatan Lompat (Default: 50)",
   PlaceholderText = "Ketik power di sini...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      local numericValue = tonumber(Text)
      if numericValue then
         _G.CustomJump = numericValue
      else
         _G.CustomJump = 50
      end
   end
})

local TouchFlingToggle = Tab:CreateToggle({
   Name = "Touch Fling (ON/OFF)",
   CurrentValue = _G.TouchFlingEnabled,
   Flag = "TouchFlingToggle",
   Callback = function(Value)
      _G.TouchFlingEnabled = Value
   end,
})

local FlingInput = Tab:CreateInput({
   Name = "Target Nama Player",
   PlaceholderText = "Ketik nama/username...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      targetPlayerName = Text
   end,
})

pcall(function()
   if FlingInput and FlingInput.Interact then
      local box = FlingInput.Interact:FindFirstChildWhichIsA("TextBox")
      if box then
         box.Size = UDim2.new(0, 150, 0, 30)
         box.TextXAlignment = Enum.TextXAlignment.Center
      end
   end
end)

local FlingButton = Tab:CreateButton({
   Name = "Fling!",
   Callback = function()
      if targetPlayerName ~= "" then
         pcall(function()
            local targetPlayer = nil
            for _, v in pairs(game:GetService("Players"):GetPlayers()) do
               if v ~= lp and (v.Name:lower():find(targetPlayerName:lower()) or v.DisplayName:lower():find(targetPlayerName:lower())) then
                  targetPlayer = v
                  break
               end
            end
            
            if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
               local myHrp = lp.Character.HumanoidRootPart
               local targetHrp = targetPlayer.Character.HumanoidRootPart
               local hum = lp.Character:FindFirstChildOfClass("Humanoid")
               
               local oldVelocity = myHrp.Velocity
               local oldRotVelocity = myHrp.RotVelocity
               local oldCframe = myHrp.CFrame
               
               local flingTime = 0.5
               local startTime = tick()
               
               while tick() - startTime < flingTime do
                  runService.Heartbeat:Wait()
                  if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                     myHrp.CFrame = targetHrp.CFrame * CFrame.new(0, 0, 0)
                     myHrp.Velocity = Vector3.new(99999, 99999, 99999)
                     myHrp.RotVelocity = Vector3.new(99999, 99999, 99999)
                  else
                     break
                  end
               end
               
               task.wait(0.1)
               myHrp.CFrame = oldCframe
               myHrp.Velocity = oldVelocity
               myHrp.RotVelocity = oldRotVelocity
               
               if hum then
                  hum:ChangeState(Enum.HumanoidStateType.Freefall)
                  task.wait(0.05)
                  hum:ChangeState(Enum.HumanoidStateType.Running)
               end
            end
         end)
      end
   end,
})

