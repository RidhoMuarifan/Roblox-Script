local spectateIndex = 1
local spectateScreenGui = nil

local function createSpectatePanel()
    if game:GetService("CoreGui"):FindFirstChild("NeftishSpectateGui") then
        game:GetService("CoreGui").NeftishSpectateGui:Destroy()
    end

    local sgui = Instance.new("ScreenGui")
    sgui.Name = "NeftishSpectateGui"
    sgui.Parent = game:GetService("CoreGui")
    spectateScreenGui = sgui

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 300, 0, 60)
    frame.Position = UDim2.new(0.5, -150, 0.85, 0)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    frame.BorderSizePixel = 0
    frame.Active = true
    frame.Draggable = true
    frame.Parent = sgui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = frame

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.4, 0)
    nameLabel.Position = UDim2.new(0, 0, 0, 5)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = "Memuat Player..."
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.Font = Enum.Font.SourceSansBold
    nameLabel.TextSize = 16
    nameLabel.Parent = frame

    local btnLeft = Instance.new("TextButton")
    btnLeft.Size = UDim2.new(0, 40, 0, 30)
    btnLeft.Position = UDim2.new(0.05, 0, 0.45, 0)
    btnLeft.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btnLeft.Text = "<"
    btnLeft.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnLeft.Font = Enum.Font.SourceSansBold
    btnLeft.TextSize = 18
    btnLeft.Parent = frame
    Instance.new("UICorner", btnLeft).CornerRadius = UDim.new(0, 5)

    local btnRight = Instance.new("TextButton")
    btnRight.Size = UDim2.new(0, 40, 0, 30)
    btnRight.Position = UDim2.new(0.95, -40, 0.45, 0)
    btnRight.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btnRight.Text = ">"
    btnRight.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnRight.Font = Enum.Font.SourceSansBold
    btnRight.TextSize = 18
    btnRight.Parent = frame
    Instance.new("UICorner", btnRight).CornerRadius = UDim.new(0, 5)

    local btnClose = Instance.new("TextButton")
    btnClose.Size = UDim2.new(0, 100, 0, 30)
    btnClose.Position = UDim2.new(0.5, -50, 0.45, 0)
    btnClose.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    btnClose.Text = "Kembali (X)"
    btnClose.TextColor3 = Color3.fromRGB(255, 255, 255)
    btnClose.Font = Enum.Font.SourceSansBold
    btnClose.TextSize = 14
    btnClose.Parent = frame
    Instance.new("UICorner", btnClose).CornerRadius = UDim.new(0, 5)

    local function updateSpectate()
        local players = {}
        for _, p in pairs(game:GetService("Players"):GetPlayers()) do
            if p ~= lp then table.insert(players, p) end
        end

        if #players == 0 then
            nameLabel.Text = "Tidak ada player lain"
            workspace.CurrentCamera.CameraSubject = lp.Character:FindFirstChildOfClass("Humanoid")
            return
        end

        if spectateIndex > #players then spectateIndex = 1 end
        if spectateIndex < 1 then spectateIndex = #players end

        local target = players[spectateIndex]
        if target and target.Character and target.Character:FindFirstChildOfClass("Humanoid") then
            nameLabel.Text = "Spectating: " .. (target.DisplayName or target.Name)
            workspace.CurrentCamera.CameraSubject = target.Character:FindFirstChildOfClass("Humanoid")
        else
            nameLabel.Text = "Player tidak memiliki karakter"
        end
    end

    btnLeft.MouseButton1Click:Connect(function()
        spectateIndex = spectateIndex - 1
        updateSpectate()
    end)

    btnRight.MouseButton1Click:Connect(function()
        spectateIndex = spectateIndex + 1
        updateSpectate()
    end)

    btnClose.MouseButton1Click:Connect(function()
        pcall(function()
            local char = lp.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                workspace.CurrentCamera.CameraSubject = hum
            end
        end)
        sgui:Destroy()
    end)

    updateSpectate()
end

